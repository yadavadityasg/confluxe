# Copy to .env and fill in. Generate the secrets with:
#   bash scripts/gen-keys.sh >> .env

# --- Postgres / JWT (filled in by gen-keys.sh) ---
POSTGRES_PASSWORD=changeme
JWT_SECRET=changeme-at-least-32-chars-long-random-string
ANON_KEY=eyJ...                    # generated, role=anon
SERVICE_ROLE_KEY=eyJ...            # generated, role=service_role

# --- Public origin ---
# With a domain (recommended): https://wiki.yourdomain.com/supabase
# IP-only smoke test:          http://<EC2_PUBLIC_IP>/supabase
PUBLIC_BASE_URL=https://wiki.yourdomain.com/supabase

# Hostname Caddy serves. Set to your domain for free HTTPS, or ":80" for plain HTTP on IP.
DOMAIN=wiki.yourdomain.com

# --- First-admin bootstrap (one-shot, idempotent) ---
# If both are set and no admin exists yet, the bootstrap service creates this account.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-now

# --- Optional: Lovable AI gateway (server-side only) ---
LOVABLE_API_KEY=
