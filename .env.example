# Copy to .env and fill in. Generate the secrets with:
#   bash scripts/gen-keys.sh >> .env
# Then set PUBLIC_BASE_URL to your EC2 public IP (or domain).

POSTGRES_PASSWORD=changeme
JWT_SECRET=changeme-at-least-32-chars-long-random-string
ANON_KEY=eyJ...                    # generated, role=anon
SERVICE_ROLE_KEY=eyJ...            # generated, role=service_role

# Public URL of the Supabase gateway. From the browser the JS client hits
# this for /auth/v1/* and /rest/v1/*. On EC2 use:  http://<EC2_PUBLIC_IP>:8000
PUBLIC_BASE_URL=http://localhost:8000

# Optional: only needed if you use Lovable AI Gateway server-side
LOVABLE_API_KEY=
